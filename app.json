{
  "expo": {
    "name": "Octara Maps",
    "slug": "octara-maps",
    "version": "3.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "octaramaps",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.octarahq.octaramaps"
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "pwa": {
        "name": "Octara Maps",
        "shortName": "Octara Maps",
        "themeColor": "#0d7ff2",
        "backgroundColor": "#101922",
        "display": "standalone",
        "startUrl": "/",
        "icon": "./assets/images/icon.png",
        "meta": {
          "appleMobileWebAppCapable": "yes",
          "appleMobileWebAppStatusBarStyle": "default"
        }
      }
    },
    "android": {
      "permissions": [
        "REQUEST_INSTALL_PACKAGES",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.octarahq.octaramaps",
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "maps.octara.xyz",
              "pathPrefix": "/place"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-localization",
      "expo-web-browser",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "192b1d89-a3d2-4b4d-ae93-5ee3c917e1b5"
      }
    },
    "owner": "octarahq"
  }
}
